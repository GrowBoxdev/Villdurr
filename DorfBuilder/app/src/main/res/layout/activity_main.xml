<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0d1117">

    <TextView
        android:id="@+id/resourceText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:textColor="#39ff7a"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:text="GOLD: 0 | ELIXIR: 0" />

    <com.growboxit.villdurr.VillageView
        android:id="@+id/villageView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp">

        <Button
            android:id="@+id/btnGoldmine"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Goldmine" />

        <Button
            android:id="@+id/btnElixir"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Elixir" />

        <Button
            android:id="@+id/btnWall"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Mauer" />

        <Button
            android:id="@+id/btnDemolish"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Abreißen" />

    </LinearLayout>

</LinearLayout>
